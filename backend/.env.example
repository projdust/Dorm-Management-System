|#PLEASE READ THIS#|#PLEASE READ THIS#|#PLEASE READ THIS#|#PLEASE READ THIS#|#PLEASE READ THIS#|#PLEASE READ THIS#|#PLEASE READ THIS#|#PLEASE READ THIS#|#PLEASE READ THIS#|#PLEASE READ THIS#

# Server
PORT=5000
NODE_ENV=development

# Database (PostgreSQL via Supabase)
# DATABASE_URL = connection pooling URL (port 6543, has ?pgbouncer=true) - used at runtime
# DIRECT_URL   = direct connection URL (port 5432) - used only for migrations
#AFTER CREATING/SETTING UP YOU LOCAL DATABASE, PASTE THE LINK HERE#
DATABASE_URL=""

DIRECT_URL=""

# JWT
JWT_ACCESS_SECRET=replace_with_a_long_random_string
JWT_REFRESH_SECRET=replace_with_a_different_long_random_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CLIENT_URL=http://localhost:5173

# Bcrypt
BCRYPT_SALT_ROUNDS=10
